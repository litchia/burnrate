{
  "name": "burnrate",
  "displayName": "BurnRate",
  "description": "Local cost & quota dashboard for Claude Code and Codex CLI - zero config, privacy-first",
  "version": "2.0.2",
  "publisher": "litchiak",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/litchia/burnrate.git"
  },
  "homepage": "https://github.com/litchia/burnrate",
  "bugs": {
    "url": "https://github.com/litchia/burnrate/issues"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Other", "Visualization"],
  "icon": "icon.png",
  "keywords": ["claude", "claude-code", "codex", "codex-cli", "openai", "anthropic", "cost", "tracking", "ai", "tokens", "quota", "burn-rate", "forecasting", "dashboard", "glm", "qwen", "kimi", "deepseek"],
  "main": "./out/extension.js",
  "l10n": "./l10n",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "burnRate.showDashboard",
        "title": "%command.showDashboard.title%"
      },
      {
        "command": "burnRate.refresh",
        "title": "%command.refresh.title%"
      }
    ],
    "configuration": {
      "title": "BurnRate",
      "properties": {
        "burnRate.language": {
          "type": "string",
          "enum": ["auto", "en", "zh-cn"],
          "enumDescriptions": [
            "%config.language.enumDescriptions.auto%",
            "%config.language.enumDescriptions.en%",
            "%config.language.enumDescriptions.zh-cn%"
          ],
          "default": "auto",
          "description": "%config.language.description%"
        },
        "burnRate.customPricing": {
          "type": "object",
          "default": {},
          "markdownDescription": "%config.customPricing.markdownDescription%"
        },
        "burnRate.spikeThresholdUsd": {
          "type": "number",
          "default": 1.0,
          "minimum": 0,
          "description": "%config.spikeThresholdUsd.description%"
        },
        "burnRate.ignoredUnpricedModels": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "markdownDescription": "%config.ignoredUnpricedModels.markdownDescription%"
        },
        "burnRate.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "%config.showStatusBar.description%"
        },
        "burnRate.statusBarRefreshSeconds": {
          "type": "number",
          "default": 300,
          "minimum": 30,
          "description": "%config.statusBarRefreshSeconds.description%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "publish:vsce": "vsce publish",
    "publish:ovsx": "ovsx publish"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.3.0"
  }
}
