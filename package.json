{
  "name": "burnrate",
  "displayName": "BurnRate",
  "description": "Local cost & quota dashboard for Claude Code and Codex CLI - zero config, privacy-first",
  "version": "2.0.0",
  "publisher": "litchia",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/litchia/burnrate.git"
  },
  "homepage": "https://github.com/litchia/burnrate",
  "bugs": {
    "url": "https://github.com/litchia/burnrate/issues"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Other", "Visualization"],
  "keywords": ["claude", "claude-code", "codex", "codex-cli", "openai", "anthropic", "cost", "tracking", "ai", "tokens", "quota", "burn-rate", "forecasting", "dashboard", "glm", "qwen", "kimi", "deepseek"],
  "main": "./out/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "commands": [
      {
        "command": "burnRate.showDashboard",
        "title": "%command.showDashboard.title%"
      },
      {
        "command": "burnRate.refresh",
        "title": "%command.refresh.title%"
      }
    ],
    "configuration": {
      "title": "BurnRate",
      "properties": {
        "burnRate.language": {
          "type": "string",
          "enum": ["auto", "en", "zh-cn"],
          "enumDescriptions": [
            "%config.language.enumDescriptions.auto%",
            "%config.language.enumDescriptions.en%",
            "%config.language.enumDescriptions.zh-cn%"
          ],
          "default": "auto",
          "description": "%config.language.description%"
        },
        "burnRate.customPricing": {
          "type": "object",
          "default": {},
          "markdownDescription": "%config.customPricing.markdownDescription%"
        },
        "burnRate.spikeThresholdUsd": {
          "type": "number",
          "default": 1.0,
          "minimum": 0,
          "description": "%config.spikeThresholdUsd.description%"
        },
        "burnRate.ignoredUnpricedModels": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "markdownDescription": "%config.ignoredUnpricedModels.markdownDescription%"
        },
        "claudeCostTracker.customPricing": {
          "type": "object",
          "default": {},
          "markdownDeprecationMessage": "**Deprecated.** Use `burnRate.customPricing` instead. The legacy key is still read until v3.0.",
          "markdownDescription": "**Deprecated** — moved to `burnRate.customPricing`."
        },
        "claudeCostTracker.spikeThresholdUsd": {
          "type": "number",
          "default": 1.0,
          "minimum": 0,
          "markdownDeprecationMessage": "**Deprecated.** Use `burnRate.spikeThresholdUsd` instead. The legacy key is still read until v3.0.",
          "description": "Deprecated — moved to burnRate.spikeThresholdUsd."
        },
        "claudeCostTracker.ignoredUnpricedModels": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "markdownDeprecationMessage": "**Deprecated.** Use `burnRate.ignoredUnpricedModels` instead. The legacy key is still read until v3.0.",
          "markdownDescription": "**Deprecated** — moved to `burnRate.ignoredUnpricedModels`."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.3.0"
  }
}
