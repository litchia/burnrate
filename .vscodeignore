# Source — only ship compiled output
src/**
!src/webview/index.html
!src/webview/main.js

# Build artifacts we don't need at runtime
out/**/*.map
tsconfig.json

# Repo metadata
.git/**
.github/**
.claude/**
.gitignore
.vscode/**
.vscode-test/**
.DS_Store
Thumbs.db

# Project docs not relevant to end users
ROADMAP.md
CLAUDE.md
AGENTS.md
CLAUDE.local.md

# Stray files from other tools
folder-alias.json
private-folder-alias.json

# Draft / WIP / contributor-only docs
*.draft.md
I18N_CONVENTIONS.md

# Safety: orphaned compiled outputs from deleted sources
out/remotePricing.*

# CLI — shipped separately as the `burnrate-cli` npm package, not in VSIX
out/cli/**
cli-pkg/**

# Icon source — only ship the PNG
icon.svg

# Node
node_modules/**
package-lock.json
*.vsix
